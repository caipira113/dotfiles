{
  "attribution": {
      "commit": "",
      "pr": ""
  },
  {{ if eq .chezmoi.os "windows" -}}
  "defaultShell": "powershell",
  "env": {
      "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  {{ end -}}
  "model": "opus[1m]",
  "autoUpdatesChannel": "latest",
  "skipAutoPermissionPrompt": true,
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [{
      "matcher": "startup|resume|compact",
      "hooks": [{
        "type": "command",
        "command": "python {{ .chezmoi.homeDir | replace `\` `/` }}/.claude/hooks/inject-excluded-claude-md.py"
      }]
    }]
  }
}
